# Next.js runtime
PORT=3000

# Backend mode
# dev: local/development setup
# build: production-like setup
WORLDCOIN_MODE=dev

# World ID verification
# Required:
WORLDCOIN_RP_ID=rp_your_rp_id        # RP ID from World Developer Portal (rp_...)
NEXT_PUBLIC_WORLDCOIN_APP_ID=app_your_app_id  # App ID from World Developer Portal (app_...)
NEXT_PUBLIC_WORLDCOIN_ACTION=upload-photo     # Action slug registered in Developer Portal

# RP signing key — required for IDKit.request() to work (generates the rp_context)
RP_SIGNING_KEY=your_ecdsa_signing_key_hex

# Optional:
# WORLDCOIN_API_KEY=...
# WORLDCOIN_VERIFY_BASE_URL=https://developer.world.org

# Postgres (Neon) for storing uploaded images + provenance
# Example:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
DATABASE_URL=

# Optional 0G proof storage (used by /api/publish-og)
# OG_STORAGE_PRIVATE_KEY=0x...
# OG_STORAGE_EVM_RPC=https://evmrpc-testnet.0g.ai
# OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Optional writable dir for ephemeral state files (backend-state + signing keys)
# Useful on serverless read-only roots; defaults to /tmp/... automatically on /var/task runtimes
# STATE_DIR=/tmp/worldcoin-miniapp-state
